# Anthropic API Key (Required)



GEMINI_API_KEY=#demo
# App Configuration
APP_TITLE=Math Mentor
DEBUG=false

# Memory & Storage
MEMORY_DB_PATH=./memory/math_memory.json
VECTOR_STORE_PATH=./rag/vector_store

# Model Settings
CLAUDE_MODEL=claude-sonnet-4-20250514
EMBEDDING_MODEL=all-MiniLM-L6-v2

# OCR Settings
OCR_ENGINE=easyocr   # options: tesseract, easyocr
OCR_CONFIDENCE_THRESHOLD=0.6

# RAG Settings
RAG_TOP_K=5
CHUNK_SIZE=500
CHUNK_OVERLAP=50
